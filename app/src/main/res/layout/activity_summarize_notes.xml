<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/accent"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/baseline_arrow_back_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="@color/surface"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Summarize Notes"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/surface"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section 1: Paste text -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section label -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Paste your notes"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/textPrimary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Copy text from your notes or textbook and paste it below."
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/textSecondary"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/editTextPaste"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:hint="Paste or type your notes here..."
                        android:gravity="top|start"
                        android:padding="14dp"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif"
                        android:background="@drawable/bg_input_earthy"
                        android:inputType="textMultiLine"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/accentMuted"/>

                    <Button
                        android:id="@+id/buttonSummarizeFromPaste"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Summarize Pasted Text"
                        android:backgroundTint="@color/accent"
                        android:textColor="@color/surface"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="14dp"
                        app:cornerRadius="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Divider with label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/accentMuted"
                    android:alpha="0.5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  OR  "
                    android:textColor="@color/textSecondary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/accentMuted"
                    android:alpha="0.5"/>
            </LinearLayout>

            <!-- Section 2: Upload document -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Upload a document"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/textPrimary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Choose a PDF or TXT file. Once loaded, tap Summarize to get a summary."
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/textSecondary"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Choose file button -->
                    <Button
                        android:id="@+id/buttonUploadDocument"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="📎  Choose File"
                        android:backgroundTint="@color/background"
                        android:textColor="@color/accent"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        app:cornerRadius="12dp"/>

                    <!-- File name badge -->
                    <LinearLayout
                        android:id="@+id/layoutFileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_file_badge_earthy"
                        android:padding="12dp"
                        android:layout_marginTop="12dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/baseline_description_24"
                            app:tint="@color/accent"/>

                        <TextView
                            android:id="@+id/textViewFileName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"
                            android:textColor="@color/textPrimary"
                            android:layout_marginStart="10dp"
                            android:ellipsize="middle"
                            android:singleLine="true"/>
                    </LinearLayout>

                    <!-- Summarize document button -->
                    <Button
                        android:id="@+id/buttonSummarizeDocument"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Summarize Document"
                        android:textColor="@color/surface"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:backgroundTint="@color/buttonDisabled"
                        android:layout_marginTop="14dp"
                        android:enabled="false"
                        app:cornerRadius="12dp"/>

                    <TextView
                        android:id="@+id/textViewHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Choose a file above to enable this button"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/accentMuted"
                        android:gravity="center"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent" android:layout_height="24dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>