<?xml version="1.0" encoding="utf-8"?>
<!--
    item_history_quiz.xml
    A single quiz type row shown inside an expanded document.
    Shows quiz type label + last score + a > arrow to open it.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="54dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Quiz type info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textQuizType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/textPrimary"
            android:textStyle="normal"/>

        <TextView
            android:id="@+id/textLastScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/textSecondary"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Right arrow -->
    <TextView
        android:id="@+id/textOpenArrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="›"
        android:textSize="22sp"
        android:textColor="@color/textSecondary"/>

</LinearLayout>