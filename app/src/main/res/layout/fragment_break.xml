    </LinearLayout>
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/breakResetButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_circle_earthy"
            android:padding="13dp"
            android:src="@drawable/baseline_reset_circle_24"
            app:tint="@color/accent"/>

        <Button
            android:id="@+id/breakStartButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginStart="24dp"
            android:backgroundTint="@color/accent"
            android:drawableStart="@drawable/baseline_play_arrow_24"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:text="Start"
            android:textAllCaps="false"
            android:textColor="@color/surface"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>