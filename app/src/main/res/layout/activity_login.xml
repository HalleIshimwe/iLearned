<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@color/background"
    >

    <!-- Logo area -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="36dp">

        <!-- Icon badge -->
        <LinearLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp">

        </LinearLayout>

        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:text="iLearned"
            android:textColor="@color/textPrimary"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_gravity="center"/>

        <TextView
            android:id="@+id/description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"
            android:text="Sign in to your account"
            android:textColor="@color/textSecondary"
            android:textSize="14sp"
            android:layout_gravity="center"/>
    </LinearLayout>

    <!-- Card container -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/surface"
        android:layout_marginEnd="30dp"
        android:layout_marginStart="30dp"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="EMAIL ADDRESS"
                android:textColor="@color/textSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/emailEditText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/custom_edit_text"
                android:hint="you@example.com"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/accentMuted"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="PASSWORD"
                android:textColor="@color/textSecondary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/loginPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/custom_edit_text"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/textPrimary"
                android:textColorHint="@color/accentMuted"/>

            <!-- Add this AFTER the password EditText and BEFORE the login button -->
            <TextView
                android:id="@+id/textForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_gravity="end"
                android:text="Forgot password?"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:paddingTop="6dp"
                android:paddingBottom="12dp"
                android:clickable="true"
                android:focusable="true"/>

            <Button
                android:id="@+id/login_btn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="@color/accent"
                android:text="Sign In"
                android:textAllCaps="false"
                android:textColor="@color/surface"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp"
                app:cornerRadius="12dp"/>

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Divider -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/accentMuted"
            android:alpha="0.5"
            android:layout_marginEnd="30dp"
            android:layout_marginStart="30dp"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  OR CONTINUE WITH  "
            android:textColor="@color/textSecondary"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:fontFamily="sans-serif-medium"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/accentMuted"
            android:alpha="0.5"
            android:layout_marginEnd="30dp"
            android:layout_marginStart="30dp"
            />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/googleLogin"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:layout_marginBottom="10dp"
        android:text="  Continue with Google "
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-medium"
        app:icon="@drawable/google_icon"
        app:iconTint="@null"
        app:backgroundTint="#1877F2"
        app:strokeColor="@color/accentMuted"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"/>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:text="Don't have an account? "
            android:textColor="@color/textSecondary"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/signUpTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Create Account"
            android:textColor="#0000FF"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>